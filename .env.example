# Supabase — quando presentes, a persistência usa o Supabase.
# Sem estas variáveis, a LP faz fallback automático para armazenamento local (.data/).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Base URL usada no payload do QR Code / validação de voucher
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Resend (e-mail de confirmação — servidor apenas)
RESEND_API_KEY=re_xxxxxxxxx
RESEND_FROM_EMAIL=atendimento@grupoalmeria.com.br

# Painel /admin e página /operador (senhas separadas por papel)
ADMIN_PASSWORD=
OPERATOR_PASSWORD=
# Segredo para assinar o cookie de sessão (gere um valor aleatório longo)
AUTH_SECRET=
# Webhook do Resend (Dashboard > Webhooks > Signing Secret, começa com whsec_)
RESEND_WEBHOOK_SECRET=
